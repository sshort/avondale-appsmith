{
  "boxShadow": "none",
  "widgetName": "RichTextTemplate",
  "columns": 24,
  "bottomRow": 41,
  "labelText": "Rich Text HTML Editor",
  "topRow": 17,
  "labelWidth": 5,
  "type": "RICH_TEXT_EDITOR_WIDGET",
  "animateLoading": true,
  "dynamicTriggerPathList": [
    {
      "key": "onTextChange"
    }
  ],
  "isToolbarHidden": false,
  "dynamicBindingPathList": [
    {
      "key": "accentColor"
    },
    {
      "key": "borderRadius"
    },
    {
      "key": "defaultText"
    },
    {
      "key": "onTextChange"
    }
  ],
  "leftColumn": 1,
  "labelPosition": "Top",
  "inputType": "html",
  "isDisabled": false,
  "flexVerticalAlignment": "top",
  "labelTextSize": "0.875rem",
  "isRequired": false,
  "rightColumn": 32,
  "isDefaultClickDisabled": true,
  "accentColor": "{{appsmith.theme.colors.primaryColor}}",
  "widgetId": "richTextTemplate01",
  "minWidth": 450,
  "isVisible": true,
  "rows": 16,
  "version": 1,
  "parentId": "emailtemplatesModalCanvas01",
  "labelAlignment": "left",
  "responsiveBehavior": "fill",
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "defaultText": "{{appsmith.store.emailTemplateDraft?.html_template || ''}}",
  "onTextChange": "{{storeValue('emailTemplateLiveHtml', RichTextTemplate.text || '')}}"
}
